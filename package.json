{
  "name": "@xmov/pure-qa-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:oss": "vue-tsc --noEmit && vite build --base /pure-qa-demo/",
