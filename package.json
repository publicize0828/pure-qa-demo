    "@xmov/asr": "file:./src/lib/asr",
    "@xmov/llm": "file:./src/lib/llm",
    "@xmov/sdk-core": "file:./src/lib/sdk-core",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "typescript": "~5.7.0",
    "vite": "^8.0.14",
    "vue-tsc": "^3.3.2"
  }
}
