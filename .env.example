# 数字人 SDK（注册获取：https://xingyun3d.com → 应用管理 → 创建横屏应用）
VITE_SDK_APP_ID=
VITE_SDK_APP_SECRET=

# LLM 大模型（阿里百炼 DashScope：https://dashscope.aliyun.com → API-KEY 管理）
VITE_LLM_API_KEY=
VITE_LLM_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_LLM_MODEL=qwen-flash

# ASR 语音识别（腾讯实时语音识别：https://console.cloud.tencent.com/casr）
VITE_ASR_APP_ID=
VITE_ASR_SECRET_ID=
VITE_ASR_SECRET_KEY=
